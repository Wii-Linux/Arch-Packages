pkgbase=npll
pkgname=(npll npll-mini)
pkgver=0.1
pkgrel=1
pkgdesc="Universal Nintendo PowerPC Linux Bootloader"
arch=('powerpc')
url="https://wii-linux.org"
license=(GPL-2.0-only)

source=(
	'git+https://github.com/Wii-Linux/NPLL'
)

sha256sums=('SKIP')
makedepends=(
	'gcc'
	'binutils'
	'glibc'
	'git'
	'armeb-none-eabi-gcc'
	'armeb-none-eabi-binutils'
)

prepare() {
	cd "${srcdir}/NPLL"
	git submodule update --init --recursive
}

build() {
	cd "${srcdir}/NPLL"
	make
}

package_npll() {
	depends=(npll-mini)
	provides=(wii-linux-bootloader)
	# technically not true but we also need to rip out gumboot-utils since it depends on gumboot
	conflicts=(gumboot gumboot-utils)
	mkdir -p "${pkgdir}/boot"
	cp "${srcdir}/NPLL/bin/npll.elf" "${pkgdir}/boot/npll.elf"
}

package_npll-mini() {
	conflicts=(gumboot gumboot-utils)
	mkdir -p "${pkgdir}/boot/bootmii"
	cp "${srcdir}/NPLL/external/mini/armboot.bin" "${pkgdir}/boot/bootmii/armboot.bin"
}
